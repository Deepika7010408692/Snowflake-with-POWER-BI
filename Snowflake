UPDATE BOOKING
SET bookingStatus='Cancelled'
WHERE bookingId=1006;

SELECT * FROM booking_stream;
DELETE FROM BOOKING
WHERE bookingId=1006;

SELECT * FROM booking_stream;

CREATE OR REPLACE TASK refresh_fact_booking
WAREHOUSE = HOTEL_WH
SCHEDULE = '5 MINUTE'
AS
INSERT INTO FACT_BOOKING
SELECT
    bookingId,
    customerId,
    roomId,
    NULL,
    bookingDate,
    bookingAmount,
    bookingStatus
FROM booking_stream;

SHOW TASKS;

ALTER TASK refresh_fact_booking RESUME;
SHOW TASKS;

INSERT INTO BOOKING
VALUES (1007,3,203,'2026-05-21',7000,'Confirmed');

SELECT * FROM FACT_BOOKING
WHERE bookingId = 1007;

ALTER TASK refresh_fact_booking SUSPEND;

CREATE OR REPLACE DYNAMIC TABLE DT_REVENUE
TARGET_LAG = '5 minutes'
WAREHOUSE = HOTEL_WH
AS
SELECT
    hotelId,
    SUM(bookingAmount) AS total_revenue
FROM FACT_BOOKING
WHERE bookingStatus != 'Cancelled'
GROUP BY hotelId;

SHOW DYNAMIC TABLES;
SELECT * FROM DT_REVENUE;

