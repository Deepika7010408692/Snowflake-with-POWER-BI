FROM @hotel_stage/customers.csv
FILE_FORMAT = csv_format;

SELECT * FROM customers;

COPY INTO rooms
FROM @hotel_stage/rooms.csv
FILE_FORMAT = (FORMAT_NAME='csv_format');

SELECT * FROM rooms;

COPY INTO bookings
FROM @hotel_stage/bookings.csv
FILE_FORMAT = (FORMAT_NAME='csv_format');

SELECT * FROM bookings;

COPY INTO feedback2
FROM @hotel_stage/feedback2.csv
FILE_FORMAT = (TYPE='CSV' SKIP_HEADER=1 FIELD_OPTIONALLY_ENCLOSED_BY='"');

SELECT * FROM feedback2;

