CREATE DATABASE HOTEL_DB;
USE DATABASE HOTEL_DB;
CREATE SCHEMA HOTEL_DB.HOTEL_SCHEMA;
USE SCHEMA HOTEL_SCHEMA;

DROP TABLE customers;

CREATE TABLE customers (
    customerId STRING PRIMARY KEY,
    customerName STRING,
    email STRING,
    city STRING,
    customerType STRING
);

DROP TABLE hotelS;

CREATE TABLE hotels (
    hotelId STRING PRIMARY KEY,
    hotelName STRING,
    location STRING,
    starRating INT,
    status STRING
);

DROP TABLE rooms;
CREATE TABLE rooms (
    roomId STRING PRIMARY KEY,
    hotelId STRING,
    roomType STRING,
    roomPrice STRING,
    roomStatus STRING
);
DROP TABLE bookings;
CREATE TABLE bookings (
    bookingId STRING PRIMARY KEY,
    customerId STRING,
    roomId STRING,
    bookingDate STRING,
    bookingAmount STRING,
    bookingStatus STRING
);

DROP TABLE feedback1;
DROP TABLE feedback2;
CREATE TABLE feedback2 (
    feedbackId STRING PRIMARY KEY,
    bookingId STRING,
    rating STRING,
    comments STRING,
    submittedAt TIMESTAMP
);



CREATE OR REPLACE STAGE hotel_stage;

CREATE OR REPLACE FILE FORMAT csv_format
TYPE = 'CSV'
SKIP_HEADER = 1;

CREATE OR REPLACE FILE FORMAT json_format
TYPE = 'JSON';

COPY INTO hotels
FROM @hotel_stage/hotels.csv
FILE_FORMAT = (FORMAT_NAME='csv_format');

SELECT * FROM hotels;

