CREATE OR REPLACE DYNAMIC TABLE DT_OCCUPANCY
TARGET_LAG = '5 minutes'
WAREHOUSE = HOTEL_WH
AS
SELECT
    roomId,
    COUNT(*) AS booking_count
FROM FACT_BOOKING
WHERE bookingStatus != 'Cancelled'
GROUP BY roomId;

SELECT * FROM DT_OCCUPANCY;

CREATE OR REPLACE VIEW VW_HOTEL_REVENUE AS
SELECT
    hotelId,
    SUM(bookingAmount) AS total_revenue
FROM FACT_BOOKING
WHERE bookingStatus != 'Cancelled'
GROUP BY hotelId;
SELECT * FROM VW_HOTEL_REVENUE;

CREATE OR REPLACE VIEW VW_OCCUPANCY AS
SELECT
    roomId,
    COUNT(*) AS occupancy_count
FROM FACT_BOOKING
WHERE bookingStatus != 'Cancelled'
GROUP BY roomId;
SELECT * FROM VW_OCCUPANCY;

CREATE OR REPLACE DYNAMIC TABLE MV_HOTEL_PERFORMANCE
TARGET_LAG = '5 minutes'
WAREHOUSE = HOTEL_WH
AS
SELECT
    hotelId,
    COUNT(bookingId) AS total_bookings,
    SUM(bookingAmount) AS total_revenue
FROM FACT_BOOKING
WHERE bookingStatus != 'Cancelled'
GROUP BY hotelId;

SELECT * FROM DT_HOTEL_PERFORMANCE;
