CREATE OR REPLACE ROLE HOTEL_ADMIN;
CREATE OR REPLACE ROLE ANALYST;
SHOW ROLES;
GRANT USAGE ON DATABASE HOTEL_DB TO ROLE HOTEL_ADMIN;
GRANT USAGE ON DATABASE HOTEL_DB TO ROLE ANALYST;
GRANT USAGE ON SCHEMA HOTEL_SCHEMA TO ROLE HOTEL_ADMIN;
GRANT USAGE ON SCHEMA HOTEL_SCHEMA TO ROLE ANALYST;


GRANT ALL PRIVILEGES
ON ALL TABLES IN SCHEMA HOTEL_SCHEMA
TO ROLE HOTEL_ADMIN;

GRANT SELECT
ON ALL TABLES IN SCHEMA HOTEL_SCHEMA
TO ROLE ANALYST;

CREATE OR REPLACE SECURE VIEW VW_CUSTOMERS_MASKED AS
SELECT
    customerId,
    customerName,
    CASE
        WHEN CURRENT_ROLE() = 'HOTEL_ADMIN' THEN email
        ELSE '*****@hidden.com'
    END AS email,
    city,
    customerType
FROM CUSTOMERS;
GRANT SELECT ON VIEW VW_CUSTOMERS_MASKED TO ROLE ANALYST;
DESC TABLE CUSTOMERS;
USE ROLE ANALYST;
SELECT customerName,email
FROM VW_CUSTOMERS_MASKED;
USE ROLE HOTEL_ADMIN;
SELECT customerName,email
FROM CUSTOMERS;
