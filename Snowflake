CREATE OR REPLACE TABLE DIM_CUSTOMER AS
SELECT
    customerId,
    customerName,
    email,
    city,
    customerType
FROM CUSTOMERS;

SELECT * FROM DIM_CUSTOMER;

CREATE OR REPLACE TABLE DIM_HOTEL AS
SELECT
    hotelId,
    hotelName,
    location,
    starRating,
    status
FROM HOTELS;

SELECT * FROM DIM_HOTEL;

CREATE OR REPLACE TABLE DIM_ROOM AS
SELECT
    roomId,
    hotelId,
    roomType,
    roomPrice,
    roomStatus
FROM ROOMS;

SELECT * FROM DIM_ROOM;

CREATE OR REPLACE TABLE FACT_BOOKING (
    bookingId STRING,
    customerId STRING,
    roomId STRING,
    hotelId STRING,
    bookingDate STRING,
    bookingAmount STRING,
    bookingStatus STRING
);

INSERT INTO FACT_BOOKING
SELECT
    b.bookingId,
    b.customerId,
    b.roomId,
    r.hotelId,
    b.bookingDate,
    b.bookingAmount,
    b.bookingStatus
FROM BOOKINGS b
JOIN ROOMS r
ON b.roomId = r.roomId;

SELECT * FROM FACT_BOOKING;

SHOW TABLES;

SELECT
    hotelId,
    SUM(bookingAmount) AS total_revenue
FROM FACT_BOOKING
GROUP BY hotelId;

CREATE OR REPLACE STREAM booking_stream
ON TABLE BOOKING;

SHOW STREAMS;

INSERT INTO BOOKING
